---
import Layout from '../layouts/Layout.astro';
import { jobs } from '../data/jobs';
---

<Layout title="Work Journey" activePage="Work Journey">
    <div class="px-6 py-10 md:px-12 lg:px-24 xl:px-48">

        <div class="flex justify-center mb-16" data-anim>
            <p class="text-lg leading-relaxed max-w-[880px] font-light text-[var(--color-text)] opacity-80">
                Even though my goal is to work in Computer Science, I have tried many different roles along the way. <br class="hidden md:block">
                I believe this experience has highly influenced me as a person, and in the following sections, I’ll explain how!
            </p>
        </div>

        <div class="max-w-[880px] mx-auto flex flex-col gap-12">
            {jobs.map((job) => (
                    <div data-gallery-item-reveal>
                        <div class="h-px bg-[var(--color-border)] w-full mb-12 opacity-50"></div>

                        {/* Title */}
                        <div class="mb-8">
                            <h2 class="text-2xl font-bold tracking-widest uppercase text-[var(--color-text)]">
                                {job.title}
                            </h2>
                        </div>

                        {/* Job content */}
                        <div class="flex flex-col gap-8">

                            <div class={`flex flex-col gap-8 ${job.layout === 'text-right' ? 'md:flex-row md:items-start' : ''}`}>

                                <div class="flex-1 flex flex-col gap-4 text-[var(--color-text)] opacity-90">
                                    {job.text
                                        .trim()
                                        .split(/\n\s*\n/)
                                        .map((paragraph) => (
                                                <p class="text-base leading-relaxed indent-6 md:indent-8 whitespace-pre-line">
                                                    {paragraph.trim()}
                                                </p>
                                        ))
                                    }
                                </div>

                                {/* Картинка для 'text-right' (якщо вона одна) */}
                                {job.layout === 'text-right' && job.images.length === 1 && (
                                        <div class="flex-shrink-0 flex justify-center">
                                            <img
                                                    src={job.images[0]}
                                                    alt={job.title}
                                                    class="w-full md:w-72 h-64 md:h-56 object-cover rounded-2xl shadow-sm border border-[var(--color-border)]"
                                            />
                                        </div>
                                )}
                            </div>

                            {/* КАРУСЕЛЬ (для мобільних) або СІТКА (для десктопа) */}
                            {job.images.length > 1 && (
                                    <div class="relative group">
                                        {/* На мобільних (до md) - карусель зі скролом. На ПК - сітка. */}
                                        <div class="flex md:grid md:grid-cols-3 gap-4 overflow-x-auto md:overflow-x-visible snap-x snap-mandatory no-scrollbar pb-4 md:pb-0">
                                            {job.images.map((img) => (
                                                    <div class="min-w-[85%] md:min-w-0 snap-center">
                                                        <img
                                                                src={img}
                                                                alt={job.title}
                                                                class="w-full h-64 md:h-60 object-cover rounded-2xl shadow-sm border border-[var(--color-border)]"
                                                        />
                                                    </div>
                                            ))}
                                        </div>

                                        {/* Підказка для мобільних: свайп */}
                                        <div class="flex md:hidden justify-center gap-1.5 mt-2">
                                            {job.images.map(() => (
                                                    <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-text)] opacity-20"></div>
                                            ))}
                                        </div>
                                    </div>
                            )}

                            {/* Специфічний випадок: 'text-right' з кількома картинками (теж у карусель) */}
                            {job.layout === 'text-right' && job.images.length > 1 && (
                                    <div class="md:hidden h-0 w-0 overflow-hidden">
                                        {/* Це пустий блок, бо логіка каруселі вище вже обробляє масиви > 1 */}
                                    </div>
                            )}
                        </div>
                    </div>
            ))}
        </div>
    </div>
</Layout>

<style>
    /* Приховуємо смугу прокрутки, але залишаємо можливість скролу */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>