---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, '')}`;
const BASE_URL = '/my-page2.0';
---
<Layout title="Main Page">
    <section class="min-h-[calc(100vh-64px)] flex flex-col lg:flex-row items-center justify-center lg:justify-between px-6 md:px-12 lg:px-24 xl:px-48 py-12 lg:py-20 gap-12">

        <div class="flex flex-col items-center lg:items-start text-center lg:text-left order-2 lg:order-1">
            <h1 class="text-6xl md:text-8xl lg:text-[100px] font-bold leading-[0.9] tracking-tight font-display text-[var(--color-text)]">
                Hello!
            </h1>
            <p class="text-xl md:text-2xl font-bold mt-6 leading-tight text-[var(--color-text)]">
                My name is Anna.<br />Welcome to my page!
            </p>
        </div>

        <div class="flex-shrink-0 order-1 lg:order-2">
            <img
                    src={`${BASE_URL}/cat.jpeg`}
                    alt="Anna"
                    class="w-64 h-64 md:w-80 md:h-80 lg:w-[450px] lg:h-[450px] xl:w-[510px] xl:h-[506px] object-cover rounded-3xl shadow-lg border border-[var(--color-border)]"
            />
        </div>

    </section>
</Layout>