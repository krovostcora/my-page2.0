---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Anna — Portfolio">
  <section class="min-h-[calc(100vh-65px)] flex items-center justify-between px-[183px] py-20 gap-10">

    <!-- Text -->
    <div data-anim>
      <h1 class="text-[100px] font-bold leading-[0.9] tracking-tight font-display">
        Hello!
      </h1>
      <p class="text-2xl font-bold mt-6 leading-tight">
        My name is Anna.<br />Welcome to my page!
      </p>
      <div class="flex gap-3 mt-8">
        <a href="/projects"
           class="px-5 py-2 rounded-full border-2 border-black bg-black text-white text-sm font-medium hover:bg-gray-800 transition-colors">
          Projects
        </a>
        <a href="/work-journey"
           class="px-5 py-2 rounded-full border-2 border-black text-sm font-medium hover:bg-black hover:text-white transition-colors">
          Work Journey
        </a>
        <a href="/gallery"
           class="px-5 py-2 rounded-full border-2 border-black text-sm font-medium hover:bg-black hover:text-white transition-colors">
          Art Gallery
        </a>
      </div>
    </div>

    <!-- Photo -->
    <!-- Заміни src на своє фото! -->
    <div data-anim class="flex-shrink-0">
      <img
        src="/your-photo.jpg"
        alt="Anna"
        class="w-[510px] h-[506px] object-cover rounded-3xl"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
      />
      <!-- Placeholder якщо фото немає -->
      <div style="display:none" class="w-[510px] h-[506px] bg-gray-100 rounded-3xl items-center justify-center text-gray-400 text-sm flex-col gap-3">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="M21 15l-5-5L5 21"/>
        </svg>
        <span>Додай своє фото сюди:<br/><code class="text-xs">public/your-photo.jpg</code></span>
      </div>
    </div>

  </section>
</Layout>
