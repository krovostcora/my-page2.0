---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';

const allTags = ['all', ...new Set(projects.flatMap(p => p.tags))];
---
<Layout title="Projects — Anna" activePage="Projects">
    <div class="max-w-7xl mx-auto px-6 md:px-12 py-10" x-data="{ showFilters: false, active: 'all' }">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">

            <button
                    @click="showFilters = !showFilters"
                    class="flex items-center gap-3 px-4 py-2 bg-gray-100 dark:bg-zinc-800 rounded-lg hover:bg-gray-200 dark:hover:bg-zinc-700 transition-all w-full md:w-auto justify-center"
            >
                <span class="text-sm font-bold dark:text-white">Filters</span>
                <svg
                        width="14" height="11"
                        viewBox="0 0 14 11"
                        class="transition-transform duration-300"
                        :class="showFilters ? 'rotate-180' : ''"
                >
                    <path d="M0 0l7 11 7-11z" class="fill-current dark:text-white"/>
                </svg>
            </button>
        </div>

        <div
                x-show="showFilters"
                x-collapse
                x-cloak
                class="mb-10"
        >
            <div class="flex gap-2 flex-wrap p-4 bg-gray-50 dark:bg-zinc-900 rounded-xl border border-gray-100 dark:border-zinc-800">
                {allTags.map(tag => (
                        <button
                                @click={`active = '${tag}'`}
                                :class={`active === '${tag}' ? 'bg-black text-white border-black' : 'bg-white text-black border-gray-200 hover:border-black dark:bg-zinc-800 dark:text-white dark:border-zinc-700 font-medium'`}
                                class="px-5 py-1.5 rounded-full border text-sm transition-all capitalize"
                        >
                            {tag}
                        </button>
                ))}
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {projects.map(project => (
                    <div
                            class="flex flex-col rounded-2xl overflow-hidden border border-gray-100 dark:border-zinc-800 shadow-sm hover:shadow-xl transition-all duration-300 group bg-white dark:bg-zinc-900 relative"
                            x-show={`active === 'all' || ${JSON.stringify(project.tags)}.includes(active)`}
                            data-anim
                    >
                        <div class="aspect-video bg-gray-100 dark:bg-zinc-800 overflow-hidden relative">
                            {project.image ? (
                                    <img
                                            src={project.image}
                                            alt={project.title}
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                    />
                            ) : (
                                    <div class="w-full h-full flex items-center justify-center text-gray-400">
                                        <svg width="40" height="40" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                                            <path d="M3 9h18M9 21V9"/>
                                        </svg>
                                    </div>
                            )}

                            <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 backdrop-blur-sm">
                                <a
                                        href={`/my-page2.0/projects/${project.id}`}
                                        class="bg-white text-black px-6 py-2.5 rounded-full font-bold text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 hover:bg-gray-100 shadow-lg"
                                >
                                    Read more  →
                                </a>
                            </div>
                        </div>

                        <div class="p-6 flex flex-col flex-grow">
                            <div class="flex flex-wrap gap-2 mb-3">
                                {project.technologies.slice(0, 3).map(tech => (
                                        <span class="text-[10px] uppercase tracking-wider font-bold text-gray-400 dark:text-zinc-500">
                                    {tech}
                                </span>
                                ))}
                            </div>

                            <h3 class="font-bold text-xl mb-2 dark:text-white leading-tight">
                                {project.title}
                            </h3>
                            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-6 flex-grow">
                                {project.description}
                            </p>

                            <div class="flex flex-col gap-2 mt-auto">
                                <div class="flex gap-2">
                                    {project.liveUrl && (
                                            <a
                                                    href={project.liveUrl}
                                                    target="_blank"
                                                    class="flex-1 text-center py-2.5 text-xs font-bold bg-black text-white dark:bg-white dark:text-black rounded-lg hover:opacity-80 transition-all"
                                            >
                                                Live Demo
                                            </a>
                                    )}
                                    {project.githubUrl && (
                                            <a
                                                    href={project.githubUrl}
                                                    target="_blank"
                                                    class="flex-1 text-center py-2.5 text-xs font-bold border border-gray-200 dark:border-zinc-700 dark:text-white rounded-lg hover:bg-gray-50 dark:hover:bg-zinc-800 transition-colors"
                                            >
                                                GitHub {project.githubBackendUrl ? 'Frontend' : ''}
                                            </a>
                                    )}
                                </div>

                                {project.githubBackendUrl && (
                                        <a
                                                href={project.githubBackendUrl}
                                                target="_blank"
                                                class="w-full text-center py-2.5 text-xs font-bold border border-gray-200 dark:border-zinc-700 dark:text-white rounded-lg hover:bg-gray-50 dark:hover:bg-zinc-800 transition-colors"
                                        >
                                            GitHub Backend
                                        </a>
                                )}
                            </div>
                        </div>
                    </div>
            ))}
        </div>
    </div>

    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer is:inline></script>
</Layout>

<style>
    /* Запобігає мерехтінню Alpine.js до завантаження скрипта */
    [x-cloak] { display: none !important; }
</style>