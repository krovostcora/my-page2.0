---
/**
 * PROJECTS PAGE
 *
 * ЯК ДОДАТИ ПРОЕКТ:
 * Редагуй масив `projects` нижче. Кожен проект — об'єкт з полями:
 * - title: назва
 * - description: короткий опис
 * - image: шлях до скріншоту (в public/)
 * - tags: масив тегів для фільтрації
 * - liveUrl: посилання на live demo (або null)
 * - githubUrl: посилання на GitHub (або null)
 */
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Portfolio Website',
    description: 'Personal website built with Astro, featuring art gallery, work history, and projects.',
    image: null,
    tags: ['design', 'code'],
    liveUrl: null,
    githubUrl: '#',
  },
  {
    title: 'UX Research Study',
    description: 'User interviews and usability testing for a mobile app. Synthesized insights into actionable recommendations.',
    image: null,
    tags: ['research', 'design'],
    liveUrl: null,
    githubUrl: null,
  },
  {
    title: 'Data Dashboard',
    description: 'Interactive visualization tool for exploring and comparing datasets.',
    image: null,
    tags: ['code'],
    liveUrl: '#',
    githubUrl: '#',
  },
  // Додавай свої проекти тут ↑
];

const allTags = ['all', ...new Set(projects.flatMap(p => p.tags))];
---
<Layout title="Projects — Anna" activePage="Projects">
  <div class="px-48 py-16">

      <!-- Filter bar -->
      <div class="flex items-center gap-3 mb-10 justify-end" data-anim>
          <span class="text-xl font-bold text-[#1A1A1A] dark:text-white">Filters</span>
          <svg width="14" height="11" viewBox="0 0 14 11" class="fill-[#1A1A1A] dark:fill-white">
              <path d="M0 0l7 11 7-11z"/>
          </svg>
      </div>

    <!-- Tag filters (Alpine.js driven) -->
    <div
      x-data="{ active: 'all' }"
      class="mb-10"
    >
      <div class="flex gap-2 flex-wrap mb-8">
        {allTags.map(tag => (
          <button
            x-on:click={`active = '${tag}'`}
            x-bind:class={`active === '${tag}' ? 'bg-black text-white border-black' : 'bg-white text-black border-gray-300 hover:border-gray-600'`}
            class="px-4 py-1 rounded-full border text-sm font-medium transition-all duration-200 capitalize"
          >
            {tag}
          </button>
        ))}
      </div>

      <!-- Projects grid -->
      <div class="flex flex-col gap-[42px]">
        {[0, 1].map(row => (
          <div class="flex gap-[42px] items-stretch">
            {projects.slice(row * 2, row * 2 + 3).map(project => (
              <div
                class="flex-1 rounded-[10px] overflow-hidden border border-gray-100 shadow-md hover:-translate-y-1 hover:shadow-xl transition-all duration-300 cursor-pointer group"
                x-show={project.tags.map(t => `active === '${t}'`).join(' || ') + " || active === 'all'"}
                data-anim
              >
                <!-- Thumbnail -->
                <div class="h-[240px] bg-gray-100 overflow-hidden relative">
                  {project.image ? (
                    <img src={project.image} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-gray-300">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <path d="M3 9h18M9 21V9"/>
                      </svg>
                    </div>
                  )}
                </div>

                <!-- Info -->
                <div class="p-5 bg-white">
                  <h3 class="font-bold text-lg mb-2 tracking-wide">{project.title}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed mb-4">{project.description}</p>

                  <div class="flex gap-2 flex-wrap mb-4">
                    {project.tags.map(tag => (
                      <span class="text-xs px-3 py-1 rounded-full bg-gray-100 text-gray-600 capitalize">{tag}</span>
                    ))}
                  </div>

                  <div class="flex gap-2">
                    {project.liveUrl && (
                      <a href={project.liveUrl} class="text-xs border border-gray-300 px-3 py-1.5 rounded-lg hover:bg-black hover:text-white hover:border-black transition-all duration-200 flex items-center gap-1">
                        ▶ Live Demo
                      </a>
                    )}
                    {project.githubUrl && (
                      <a href={project.githubUrl} class="text-xs border border-gray-300 px-3 py-1.5 rounded-lg hover:bg-black hover:text-white hover:border-black transition-all duration-200">
                        GitHub Repo
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

  </div>

  <!-- Alpine.js для фільтрів -->
  <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer is:inline></script>
</Layout>
