---
import Layout from '../../layouts/Layout.astro';
import {projects} from '../../data/projects.ts';
import {BASE_URL} from '../../utils/base';
import {Image} from 'astro:assets';
import {useTranslations, ui} from '../../utils/i18n';

export function getStaticPaths() {
    return [
        {params: {lang: 'en'}},
        {params: {lang: 'uk'}},
        {params: {lang: 'es'}}
    ];
}

const {lang = 'en'} = Astro.params;
const currentLang = (lang in ui ? lang : 'en') as keyof typeof ui;
const t = useTranslations(currentLang);

const getT = (field: any) => {
    if (!field) return "";
    if (typeof field === 'string') return field;
    return field[currentLang] || field['en'] || "";
};

const allTags = ['all', ...new Set(projects.flatMap(p => p.tags))];
---

<Layout title={t('projects.title')} activePage="Projects">
    <div class="max-w-7xl mx-auto px-6 md:px-12 py-10" x-data="{ active: 'all' }">

        <!-- Filter bar -->
        <div class="mb-12">
            <div class="flex items-center gap-2 overflow-x-auto no-scrollbar pb-2 -mx-4 px-4 md:mx-0 md:px-0">

                <span class="hidden md:block text-[10px] font-black uppercase tracking-widest text-muted mr-2 opacity-60 whitespace-nowrap">
                    {t('projects.filters')}
                </span>

                {allTags.map(tag => (
                        <button
                                @click={`active = '${tag}'`}
                                :class={`active === '${tag}'
                            ? 'border-accent text-accent bg-surface font-black'
                            : 'border-border text-muted hover:border-border-strong hover:text-text bg-surface'`}
                                class="px-5 py-2 rounded-full border text-xs font-bold transition-all duration-200 capitalize whitespace-nowrap"
                        >
                            {tag}
                        </button>
                ))}
            </div>
        </div>

        <!-- Project grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {projects.map(project => (
                    <article
                            class="flex flex-col rounded-2xl overflow-hidden border border-border shadow-sm hover:shadow-lg transition-all duration-300 group bg-surface"
                            x-show={`active === 'all' || ${JSON.stringify(project.tags)}.includes(active)`}
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 scale-95"
                            x-transition:enter-end="opacity-100 scale-100"
                    >
                        <!-- Thumbnail -->
                        <div class="aspect-video bg-raised overflow-hidden relative">
                            {project.image ? (
                                    <Image
                                            src={project.image}
                                            alt={getT(project.title)}
                                            width={600}
                                            height={340}
                                            quality="mid"
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                    />
                            ) : (
                                    <div class="w-full h-full flex items-center justify-center text-muted">
                                        <svg width="40" height="40" viewBox="0 0 24 24" stroke="currentColor"
                                             stroke-width="1.5" fill="none">
                                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                                            <path d="M3 9h18M9 21V9"/>
                                        </svg>
                                    </div>
                            )}

                            <!-- Hover overlay -->
                            <div class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 backdrop-blur-[2px]">
                                <a
                                        href={`${BASE_URL}${lang}/projects/${project.id}`}
                                        class="bg-white text-black px-7 py-2.5 rounded-full font-bold text-sm
       transform translate-y-3 group-hover:translate-y-0
       transition-all duration-300 hover:opacity-85 shadow-lg"
                                >
                                    {t('projects.readMore')} →
                                </a>
                            </div>
                        </div>

                        <!-- Card body -->
                        <div class="p-6 flex flex-col flex-grow">

                            <!-- Tech tags -->
                            <div class="flex flex-wrap gap-x-3 gap-y-1 mb-3">
                                {project.technologies.slice(0, 3).map(tech => (
                                        <span class="text-[10px] uppercase tracking-wider font-bold text-muted">
                                    {tech}
                                </span>
                                ))}
                            </div>

                            <!-- Title + description -->
                            <h3 class="font-bold text-xl mb-2 text-text leading-tight">
                                {getT(project.title)}
                            </h3>
                            <p class="text-sm text-muted leading-relaxed mb-6 flex-grow">
                                {getT(project.description)}
                            </p>

                            <!-- Action buttons — однаковий стиль, без виділення -->
                            <div class="flex flex-col gap-2 mt-auto">
                                <div class="flex gap-2">
                                    {project.liveUrl && (
                                            <a
                                                    href={project.liveUrl}
                                                    target="_blank"
                                                    class="flex-1 text-center py-2.5 text-xs font-bold rounded-lg
                                               border border-border text-text hover:bg-raised transition-colors"
                                            >
                                                Live Demo
                                            </a>
                                    )}
                                    {project.githubUrl && (
                                            <a
                                                    href={project.githubUrl}
                                                    target="_blank"
                                                    class="flex-1 text-center py-2.5 text-xs font-bold rounded-lg
                                               border border-border text-text hover:bg-raised transition-colors"
                                            >
                                                GitHub {project.githubBackendUrl ? 'Frontend' : ''}
                                            </a>
                                    )}
                                </div>
                                {project.githubBackendUrl && (
                                        <a
                                                href={project.githubBackendUrl}
                                                target="_blank"
                                                class="w-full text-center py-2.5 text-xs font-bold rounded-lg
                                           border border-border text-text hover:bg-raised transition-colors"
                                        >
                                            GitHub Backend
                                        </a>
                                )}
                            </div>
                        </div>
                    </article>
            ))}
        </div>
    </div>

    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer is:inline></script>
</Layout>

<style>
    [x-cloak] {
        display: none !important;
    }
</style>