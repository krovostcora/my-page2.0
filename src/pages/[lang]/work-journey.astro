---
import Layout from '../../layouts/Layout.astro';
import {jobs} from '../../data/jobs';
import {projects} from '../../data/projects';
import {BASE_URL} from '../../utils/base';
import {Image} from 'astro:assets';
import { useTranslations, ui } from '../../utils/i18n';

export function getStaticPaths() {
    return [
        {params: {lang: 'en'}},
        {params: {lang: 'uk'}},
        {params: {lang: 'es'}}
    ];
}

const {lang = 'en'} = Astro.params;
const currentLang = (lang in ui ? lang : 'en') as keyof typeof ui;
const t = useTranslations(currentLang);
---

<Layout title={t('work.title')} activePage={t('nav.work')}>
    <div class="px-6 py-10 md:px-12 lg:px-24 xl:px-48">

        <div class="flex justify-center mb-20 text-center">
            <div class="max-w-[880px]">
                <p class="text-lg leading-relaxed font-light text-muted opacity-80 italic">
                    {t('work.intro')}
                </p>
            </div>
        </div>

        <div class="max-w-[880px] mx-auto flex flex-col gap-32">
            {jobs.map((job, jobIndex) => (
                    <section data-work-section class="group">
                        <div class="flex items-center gap-4 mb-8">
                            <div class="h-0.5 bg-[var(--color-accent)] flex-grow opacity-30"></div>
                            <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[var(--color-accent)] whitespace-nowrap">
                                {job.period || "Experience"}
                            </span>
                            <div class="h-0.5 bg-border w-24 opacity-50"></div>
                        </div>

                        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-text mb-10 transition-colors duration-300">
                            {job.title[currentLang] || job.title.en}
                        </h2>

                        <div class="flex flex-col gap-10">
                            <div class={`flex flex-col gap-10 ${job.layout === 'text-right' ? 'md:flex-row' : ''}`}>
                                <div class="flex-1 flex flex-col gap-6 text-text">
                                    {(job.text[currentLang] || job.text.en).split(/\n\s*\n/).map((p) => (
                                            <p class="text-base leading-relaxed opacity-90 whitespace-pre-line">
                                                {p.trim()}
                                            </p>
                                    ))}

                                    {job.projectLink && (() => {
                                        const projectId = job.projectLink.split('/').pop();
                                        const projectData = projects.find(p => p.id === projectId);
                                        const localizedProjectLink = `${BASE_URL}${lang}/projects/${projectId}`;

                                        return (
                                                <div class="flex flex-col sm:flex-row gap-4 mt-4 w-full md:max-w-[420px]">
                                                    <a
                                                            href={localizedProjectLink}
                                                            class="flex-1 text-center py-3 text-[10px] font-black uppercase tracking-widest border border-[var(--color-accent)] text-text rounded-full hover:bg-[var(--color-accent)] hover:text-white transition-all"
                                                    >
                                                        {t('work.details')}
                                                    </a>
                                                    {projectData?.liveUrl && (
                                                            <a
                                                                    href={projectData.liveUrl}
                                                                    target="_blank"
                                                                    class="flex-1 text-center py-3 text-[10px] font-black uppercase tracking-widest bg-surface-raised border border-[var(--color-accent)] text-text rounded-full hover:bg-[var(--color-accent)] hover:text-white transition-all shadow-sm"
                                                            >
                                                                Live Demo
                                                            </a>
                                                    )}
                                                </div>
                                        );
                                    })()}
                                </div>

                                {job.layout === 'text-right' && job.images.length === 1 && (
                                        <div class="overflow-hidden rounded-2xl border border-border shadow-md flex-shrink-0 w-full md:w-80 h-72">
                                            <Image
                                                    src={job.images[0]}
                                                    alt={job.title[currentLang] || job.title.en}
                                                    width={600}
                                                    height={450}
                                                    quality="mid"
                                                    class="w-full h-full object-cover"
                                            />
                                        </div>
                                )}
                            </div>

                            {job.images.length > 1 && (
                                    <div class="relative">
                                        {/* mobile caroucel */}
                                        <div class="md:hidden overflow-hidden rounded-xl border border-border bg-zinc-950 shadow-lg">
                                            <div class="relative aspect-square w-full overflow-hidden">
                                                <div
                                                        data-carousel-id={jobIndex}
                                                        class="job-carousel flex h-full w-full cursor-grab active:cursor-grabbing scroll-smooth [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden overflow-x-auto snap-x snap-mandatory gap-0"
                                                >
                                                    {job.images.map((img, imgIndex) => (
                                                            <div class="min-w-full h-full flex-shrink-0 select-none snap-center">
                                                                <Image
                                                                        src={img}
                                                                        alt={`Work experience ${imgIndex + 1}`}
                                                                        width={800}
                                                                        quality="mid"
                                                                        class="w-full h-full object-cover pointer-events-none"
                                                                />
                                                            </div>
                                                    ))}
                                                </div>
                                            </div>
                                            <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 pointer-events-none">
                                                {job.images.map(() => (
                                                        <div class="w-1.5 h-1.5 rounded-full bg-white/20"></div>
                                                ))}
                                            </div>
                                        </div>

                                        {/* desktop grid */}
                                        <div class="hidden md:grid grid-cols-3 gap-4">
                                            {job.images.map((img) => (
                                                    <div class="overflow-hidden rounded-xl border border-border aspect-square">
                                                        <Image
                                                                src={img}
                                                                alt="Work experience image"
                                                                width={500}
                                                                height={500}
                                                                quality="mid"
                                                                class="w-full h-full object-cover"
                                                        />
                                                    </div>
                                            ))}
                                        </div>
                                    </div>
                            )}
                        </div>
                    </section>
            ))}
        </div>
    </div>
</Layout>

<script>
    function initWorkPage() {
        const sections = document.querySelectorAll('[data-work-section]');
        const observerOptions = {
            root: null,
            rootMargin: '-25% 0px -25% 0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-active');
                    entry.target.classList.remove('is-not-active');
                } else {
                    entry.target.classList.remove('is-active');
                    entry.target.classList.add('is-not-active');
                }
            });
        }, observerOptions);

        sections.forEach(section => observer.observe(section));

        const carousels = document.querySelectorAll('.job-carousel');

        carousels.forEach(carousel => {
            let isDown = false;
            let startX: number;
            let scrollLeft: number;

            carousel.addEventListener('mousedown', (e: any) => {
                isDown = true;
                startX = e.pageX - (carousel as HTMLElement).offsetLeft;
                scrollLeft = carousel.scrollLeft;
                carousel.classList.remove('scroll-smooth');
            });

            carousel.addEventListener('mouseleave', () => { isDown = false; });
            carousel.addEventListener('mouseup', () => {
                isDown = true;
                isDown = false;
                carousel.classList.add('scroll-smooth');
            });

            carousel.addEventListener('mousemove', (e: any) => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.pageX - (carousel as HTMLElement).offsetLeft;
                const walk = (x - startX) * 2;
                carousel.scrollLeft = scrollLeft - walk;
            });
        });
    }

    initWorkPage();
    document.addEventListener('astro:after-swap', initWorkPage);
</script>