---
import '../styles/global.css';
import Logo from "../components/icons/Logo.astro";
import ThemeIcon from "../components/icons/ThemeIcon.astro";
import LangIcon from "../components/icons/LangIcon.astro";

interface Props {
    title?: string;
    activePage?: string;
}
const { title = "My Portfolio", activePage = "" } = Astro.props;

const navLinks = [
    { name: 'Home', href: '/' },
    { name: 'Work Journey', href: '/work-journey' },
    { name: 'Art Gallery', href: '/gallery' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
</head>

<body class="selection:bg-zinc-200 dark:selection:bg-zinc-800 transition-colors duration-300 bg-white dark:bg-zinc-900">

<header
        id="main-header"
        class="fixed top-0 left-0 w-full z-[60] px-6 md:px-12 py-5 flex justify-between items-center transition-colors duration-300 bg-white/80 dark:bg-zinc-900/80 backdrop-blur-lg border-b border-zinc-100 dark:border-zinc-800"
>
    <div class="flex-shrink-0">
        <a href="/" class="block hover:opacity-70 transition-opacity">
            <Logo />
        </a>
    </div>

    <div class="flex items-center gap-4 md:gap-8">
        <nav class="hidden md:flex gap-8">
            {navLinks.map(link => (
                    <a
                            href={link.href}
                            class={`text-sm font-medium uppercase tracking-widest transition-colors hover:text-zinc-500 ${activePage === link.name ? 'text-zinc-900 dark:text-white' : 'text-zinc-400'}`}
                    >
                        {link.name}
                    </a>
            ))}
        </nav>

        <div class="flex items-center gap-2 md:gap-4">
            <button id="theme-toggle" class="p-2 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-full transition-colors text-zinc-900 dark:text-white">
                <ThemeIcon />
            </button>
            <button class="p-2 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-full transition-colors text-zinc-900 dark:text-white">
                <LangIcon />
            </button>

            <button id="mobile-menu-open" class="md:hidden p-2 text-zinc-900 dark:text-white focus:outline-none" aria-label="Open Menu">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 8h16M4 16h16" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
    </div>
</header>

<div
        id="mobile-menu"
        class="fixed inset-0 z-[100] bg-white dark:bg-zinc-950 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
>
    <button id="mobile-menu-close" class="absolute top-8 right-8 p-4 text-zinc-900 dark:text-white">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
        </svg>
    </button>

    <nav class="flex flex-col items-center gap-10">
        {navLinks.map(link => (
                <a
                        href={link.href}
                        class="mobile-link text-2xl font-bold uppercase tracking-tighter text-zinc-900 dark:text-white"
                >
                    {link.name}
                </a>
        ))}
    </nav>
</div>

<main class="pt-24 min-h-screen">
    <slot />
</main>

<footer class="px-6 md:px-12 py-12 border-t border-zinc-100 dark:border-zinc-800/50 text-center md:text-left">
    <p class="text-xs text-zinc-400 uppercase tracking-[0.2em]">Designed with heart • 2026</p>
</footer>

<script is:inline>
    // Швидкий перемикач теми
    document.getElementById('theme-toggle').addEventListener('click', function () {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
</script>

<script>
    declare const gsap: any;
    declare const ScrollTrigger: any;

    function initHeaderScroll() {
        const header = document.getElementById('main-header');
        if (!header) return;

        let lastScroll = 0;

        // Логіка Smart Header: приховування при скролі
        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;

            if (currentScroll <= 60) {
                header.style.transform = 'translateY(0)';
                return;
            }

            if (currentScroll > lastScroll) {
                // Скрол вниз — ховаємо
                header.style.transform = 'translateY(-100%)';
            } else {
                // Скрол вгору — показуємо
                header.style.transform = 'translateY(0)';
            }
            lastScroll = currentScroll;
        });
    }

    function initAnimations() {
        if (typeof gsap === 'undefined') return;
        gsap.registerPlugin(ScrollTrigger);

        gsap.from('[data-anim]', {
            y: 30,
            opacity: 0,
            duration: 1,
            ease: 'power3.out',
        });

        document.querySelectorAll('[data-gallery-item-reveal]').forEach((item) => {
            gsap.from(item, {
                scrollTrigger: {
                    trigger: item,
                    start: 'top 92%',
                    toggleActions: 'play none none none'
                },
                y: 40,
                opacity: 0,
                duration: 0.8,
                ease: 'power2.out',
            });
        });
    }

    function initMobileMenu() {
        const openBtn = document.getElementById('mobile-menu-open');
        const closeBtn = document.getElementById('mobile-menu-close');
        const menu = document.getElementById('mobile-menu');
        const links = document.querySelectorAll('.mobile-link');

        if (!openBtn || !closeBtn || !menu) return;

        const tl = gsap.timeline({ paused: true });

        tl.to(menu, {
            opacity: 1,
            pointerEvents: 'auto',
            duration: 0.3,
            ease: 'power2.out'
        });

        tl.from(links, {
            y: 40,
            opacity: 0,
            stagger: 0.1,
            duration: 0.4,
            ease: 'power3.out'
        }, "-=0.1");

        openBtn.addEventListener('click', () => {
            tl.play();
            document.body.style.overflow = 'hidden';
        });

        closeBtn.addEventListener('click', () => {
            tl.reverse();
            document.body.style.overflow = '';
        });

        links.forEach(link => {
            link.addEventListener('click', () => {
                tl.reverse();
                document.body.style.overflow = '';
            });
        });
    }

    // Ініціалізація
    initHeaderScroll();
    initAnimations();
    initMobileMenu();

    document.addEventListener('astro:after-swap', () => {
        initHeaderScroll();
        initAnimations();
        initMobileMenu();
    });
</script>
</body>
</html>