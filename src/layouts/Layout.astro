---
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import '../styles/global.css';

import Logo from "../components/icons/Logo.astro";
import ThemeIcon from "../components/icons/ThemeIcon.astro";
import LangIcon from "../components/icons/LangIcon.astro";

interface Props {
    title?: string;
    activePage?: string;
}
const { title = "My Portfolio", activePage = "" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
</head>
<body class="bg-white text-black font-sans">

<nav class="fixed top-0 left-0 right-0 z-50 bg-dark h-16 flex items-center px-4">
    <div class="flex items-center justify-between w-full px-6">

        <a href="/" class="w-10 h-10 flex-shrink-0 hover:opacity-80 transition-opacity">
            <Logo class="w-full h-full text-white" />
        </a>

        <div class="flex font-bold items-center gap-1 bg-nav-bg rounded-2xl p-1.5">
            {[
                { href: '/projects', label: 'Projects' },
                { href: '/work-journey', label: 'Work Journey' },
                { href: '/gallery', label: 'Art Gallery' },
            ].map(({ href, label }) => (
                    <a
                            href={href}
                            class={`px-4 py-1.5 rounded-xl text-base font-bold transition-colors ${
                                activePage === label
                                    ? 'bg-white text-black'
                                    : 'text-muted hover:text-white'
                            }`}
                    >
                        {label}
                    </a>
            ))}
        </div>

        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="group w-6 h-6 flex items-center justify-center transition-opacity" title="Toggle dark mode">
                <ThemeIcon class="text-muted group-hover:text-white transition-colors duration-200" />
            </button>

            <button class="group w-6 h-6 flex items-center justify-center transition-opacity" title="Toggle language">
                <LangIcon class="text-muted group-hover:text-white transition-colors duration-200" />
            </button>
        </div>

    </div>
</nav>

<main class="pt-16">
    <slot />
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Animation for elements appearing on the screen
        const elements = document.querySelectorAll('[data-anim]');
        if (elements.length > 0) {
            gsap.from(elements, {
                y: 30,
                opacity: 0,
                duration: 0.7,
                stagger: 0.1,
                ease: 'power3.out',
            });
        }

        // ScrollTrigger for Gallery images
        const galleryItems = document.querySelectorAll('[data-gallery-item]');
        galleryItems.forEach((item, i) => {
            gsap.from(item, {
                scrollTrigger: {
                    trigger: item,
                    start: 'top 90%',
                },
                y: 40,
                opacity: 0,
                duration: 0.6,
                delay: (i % 3) * 0.1,
                ease: 'power2.out',
            });
        });

        // ScrollTrigger for job items
        const jobItems = document.querySelectorAll('[data-job-item]');
        jobItems.forEach((item) => {
            gsap.from(item, {
                scrollTrigger: {
                    trigger: item,
                    start: 'top 85%',
                },
                x: -20,
                opacity: 0,
                duration: 0.5,
                ease: 'power2.out',
            });
        });
    });
</script>
</body>
</html>