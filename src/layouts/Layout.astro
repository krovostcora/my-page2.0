---
import '../styles/global.css';
import Logo from "../components/icons/Logo.astro";
import ThemeIcon from "../components/icons/ThemeIcon.astro";
import LangIcon from "../components/icons/LangIcon.astro";
import { BASE_URL } from '../utils/base';
import { useTranslations } from '../utils/i18n';

interface Props {
    title?: string;
    activePage?: string;
}

const { lang = 'en' } = Astro.params;
const t = useTranslations(lang as any);
const { title = "My Portfolio", activePage = "" } = Astro.props;

const navLinks = [
    { href: `${BASE_URL}${lang}/projects`, label: t('nav.projects') },
    { href: `${BASE_URL}${lang}/work-journey`, label: t('nav.work') },
    { href: `${BASE_URL}${lang}/gallery`, label: t('nav.gallery') },
];

const locales = [
    { code: 'en', label: 'EN' },
    { code: 'uk', label: 'UA' },
    { code: 'es', label: 'ES' }
];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link
            rel="preload"
            href="/my-page2.0/fonts/KyivTypeSans-Regular-.woff2"
            as="font"
            type="font/woff2"
            crossorigin
    />

    <script is:inline>
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
</head>

<body class="font-sans transition-colors duration-300">

<nav id="main-header" class="fixed top-0 left-0 right-0 z-50 bg-dark h-16 flex items-center transition-transform duration-300">
    <div class="flex items-center justify-between w-full px-6 md:px-12">
        <a href={`${BASE_URL}${lang}/`} class="w-10 h-10 flex-shrink-0 hover:opacity-80 transition-opacity">
            <Logo class="w-full h-full text-white" />
        </a>

        <div class="hidden md:flex font-bold items-center gap-1 bg-nav-bg rounded-2xl p-1.5">
            {navLinks.map(({ href, label }) => (
                    <a href={href} class={`px-4 py-1.5 rounded-xl text-base font-bold transition-colors ${activePage === label ? 'bg-white text-black' : 'text-muted hover:text-white'}`}>
                        {label}
                    </a>
            ))}
        </div>

        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="group w-6 h-6 flex items-center justify-center" title="Toggle dark mode">
                <ThemeIcon class="text-muted group-hover:text-white transition-colors" />
            </button>

            <!-- Language switcher -->
            <div class="relative group">
                <button class="group w-6 h-6 flex items-center justify-center" title="Toggle language">
                    <LangIcon class="text-muted group-hover:text-white transition-colors" />
                </button>
                <div class="absolute right-0 mt-0 pt-2 w-20 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all">
                    <div class="bg-white dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 rounded-xl shadow-xl overflow-hidden">
                        {locales.map((loc) => (
                                <button
                                        data-lang={loc.code}
                                        class={`lang-switch-btn w-full text-left px-4 py-2 text-[10px] font-bold hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors ${lang === loc.code ? 'text-blue-500' : 'text-black dark:text-white'}`}
                                >
                                    {loc.label}
                                </button>
                        ))}
                    </div>
                </div>
            </div>

            <button id="mobile-menu-open" class="md:hidden w-6 h-6 flex items-center justify-center text-white">
                <svg width="24" height="24" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 8h16M4 16h16" stroke-linecap="round"/></svg>
            </button>
        </div>
    </div>
</nav>

<div id="mobile-menu" class="fixed inset-0 z-[100] bg-white dark:bg-black flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <button id="mobile-menu-close" class="absolute top-8 right-8 p-4 text-black dark:text-white">
        <svg width="32" height="32" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>
    </button>
    <nav class="flex flex-col items-center gap-8">
        <a href={`${BASE_URL}${lang}/`} class="mobile-link text-4xl font-bold uppercase tracking-tighter text-black dark:text-white">{t('nav.home')}</a>
        {navLinks.map(link => (
                <a href={link.href} class="mobile-link text-4xl font-bold uppercase tracking-tighter text-black dark:text-white">{link.label}</a>
        ))}
    </nav>
</div>

<main class="pt-16">
    <slot />
</main>

<script is:inline>
    const btn = document.getElementById('theme-toggle');
    if (btn) {
        btn.onclick = () => {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        };
    }
</script>

<!-- Language switch logic: saves preference + preserves current page -->
<script is:inline>
    function switchLanguage(newLang) {
        // 1. Save preference
        localStorage.setItem('lang', newLang);

        // 2. Replace the lang segment in the current URL
        //    Handles: /base/en/, /base/en/projects, /base/en/projects/123
        const path = window.location.pathname;
        const newPath = path.replace(/\/(en|uk|es)(\/|$)/, '/' + newLang + '$2');

        window.location.href = newPath;
    }

    document.querySelectorAll('.lang-switch-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            switchLanguage(this.dataset.lang);
        });
    });
</script>

<script>
    declare const gsap: any;

    function initLayout() {
        const header = document.getElementById('main-header');
        const openBtn = document.getElementById('mobile-menu-open');
        const closeBtn = document.getElementById('mobile-menu-close');
        const menu = document.getElementById('mobile-menu');
        const links = document.querySelectorAll('.mobile-link');

        let lastScroll = 0;
        const handleScroll = () => {
            const currentScroll = window.scrollY;
            if (header) {
                header.style.transform = (currentScroll > lastScroll && currentScroll > 60)
                    ? 'translateY(-100%)'
                    : 'translateY(0)';
            }
            lastScroll = currentScroll;
        };

        window.removeEventListener('scroll', handleScroll);
        window.addEventListener('scroll', handleScroll, { passive: true });

        if (openBtn && closeBtn && menu && typeof gsap !== 'undefined') {
            const tl = gsap.timeline({ paused: true });
            tl.to(menu, { opacity: 1, pointerEvents: 'auto', duration: 0.3 })
                .from(links, { y: 20, opacity: 0, stagger: 0.1, duration: 0.3 }, "-=0.2");

            openBtn.onclick = () => {
                tl.play();
                document.body.style.overflow = 'hidden';
            };

            const closeMenu = () => {
                tl.reverse();
                document.body.style.overflow = '';
            };

            closeBtn.onclick = closeMenu;
            links.forEach(link => {
                (link as HTMLElement).onclick = closeMenu;
            });
        }
    }

    initLayout();
    document.addEventListener('astro:after-swap', initLayout);
</script>
</body>
</html>