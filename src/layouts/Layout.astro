---
import '../styles/global.css';
import Logo from "../components/icons/Logo.astro";
import ThemeIcon from "../components/icons/ThemeIcon.astro";
import LangIcon from "../components/icons/LangIcon.astro";

interface Props {
    title?: string;
    activePage?: string;
}
const { title = "My Portfolio", activePage = "" } = Astro.props;

const navLinks = [
    { href: '/projects', label: 'Projects' },
    { href: '/work-journey', label: 'Work Journey' },
    { href: '/gallery', label: 'Art Gallery' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
</head>

<body class="font-sans">

<nav id="main-header" class="fixed top-0 left-0 right-0 z-50 bg-dark h-16 flex items-center transition-transform duration-300">
    <div class="flex items-center justify-between w-full px-6 md:px-12">

        <a href="/" class="w-10 h-10 flex-shrink-0 hover:opacity-80 transition-opacity">
            <Logo class="w-full h-full text-white" />
        </a>

        <div class="hidden md:flex font-bold items-center gap-1 bg-nav-bg rounded-2xl p-1.5">
            {navLinks.map(({ href, label }) => (
                    <a
                            href={href}
                            class={`px-4 py-1.5 rounded-xl text-base font-bold transition-colors ${
                                activePage === label
                                    ? 'bg-white text-black'
                                    : 'text-muted hover:text-white'
                            }`}
                    >
                        {label}
                    </a>
            ))}
        </div>

        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="group w-6 h-6 flex items-center justify-center" title="Toggle dark mode">
                <ThemeIcon class="text-muted group-hover:text-white transition-colors duration-200" />
            </button>

            <button class="group w-6 h-6 flex items-center justify-center" title="Toggle language">
                <LangIcon class="text-muted group-hover:text-white transition-colors duration-200" />
            </button>

            <button id="mobile-menu-open" class="md:hidden w-6 h-6 flex items-center justify-center text-white">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 8h16M4 16h16" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
    </div>
</nav>

<div
        id="mobile-menu"
        class="fixed inset-0 z-[100] bg-white dark:bg-black flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
>
    <button id="mobile-menu-close" class="absolute top-8 right-8 p-4 text-black dark:text-white">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
        </svg>
    </button>

    <nav class="flex flex-col items-center gap-8">
        <a href="/" class="mobile-link text-4xl font-bold uppercase tracking-tighter text-black dark:text-white">Home</a>
        {navLinks.map(link => (
                <a
                        href={link.href}
                        class="mobile-link text-4xl font-bold uppercase tracking-tighter text-black dark:text-white"
                >
                    {link.label}
                </a>
        ))}
    </nav>
</div>

<main class="pt-16">
    <slot />
</main>

<script is:inline>
    document.getElementById('theme-toggle').addEventListener('click', function () {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
</script>

<script>
    declare const gsap: any;
    declare const ScrollTrigger: any;

    function initLogic() {
        // Smart Header (Ховається/з'являється)
        const header = document.getElementById('main-header');
        let lastScroll = 0;
        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;
            if (currentScroll <= 60) {
                header.style.transform = 'translateY(0)';
                return;
            }
            if (currentScroll > lastScroll) {
                header.style.transform = 'translateY(-100%)';
            } else {
                header.style.transform = 'translateY(0)';
            }
            lastScroll = currentScroll;
        });

        // GSAP анімації тексту та картинок
        if (typeof gsap !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);
            gsap.from('[data-anim]', { y: 30, opacity: 0, duration: 1, ease: 'power3.out' });
            document.querySelectorAll('[data-gallery-item-reveal]').forEach((item) => {
                gsap.from(item, {
                    scrollTrigger: { trigger: item, start: 'top 92%', toggleActions: 'play none none none' },
                    y: 40, opacity: 0, duration: 0.8, ease: 'power2.out'
                });
            });
        }

        // Мобільне меню
        const openBtn = document.getElementById('mobile-menu-open');
        const closeBtn = document.getElementById('mobile-menu-close');
        const menu = document.getElementById('mobile-menu');
        const links = document.querySelectorAll('.mobile-link');

        if (openBtn && closeBtn && menu) {
            const tl = gsap.timeline({ paused: true });
            tl.to(menu, { opacity: 1, pointerEvents: 'auto', duration: 0.3 });
            tl.from(links, { y: 20, opacity: 0, stagger: 0.1, duration: 0.3 }, "-=0.2");

            openBtn.onclick = () => { tl.play(); document.body.style.overflow = 'hidden'; };
            closeBtn.onclick = () => { tl.reverse(); document.body.style.overflow = ''; };
            links.forEach(l => l.onclick = () => { tl.reverse(); document.body.style.overflow = ''; });
        }
    }

    initLogic();
    document.addEventListener('astro:after-swap', initLogic);
</script>
</body>
</html>