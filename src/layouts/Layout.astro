---
import '../styles/global.css';

import Logo from "../components/icons/Logo.astro";
import ThemeIcon from "../components/icons/ThemeIcon.astro";
import LangIcon from "../components/icons/LangIcon.astro";

interface Props {
    title?: string;
    activePage?: string;
}
const { title = "My Portfolio", activePage = "" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!--
        КРОК 1: Читаємо тему ДО рендеру — без flash.
        is:inline = виконується синхронно, Astro не чіпає.
    -->
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
</head>

<!--
    body НЕ має класів bg/text — кольором керує CSS через var(--color-bg).
    Так ми не залежимо від того чи Tailwind згенерував потрібний клас.
-->
<body class="font-sans">

<nav class="fixed top-0 left-0 right-0 z-50 bg-dark h-16 flex items-center px-4">
    <div class="flex items-center justify-between w-full px-6">

        <a href="/" class="w-10 h-10 flex-shrink-0 hover:opacity-80 transition-opacity">
            <Logo class="w-full h-full text-white" />
        </a>

        <div class="flex font-bold items-center gap-1 bg-nav-bg rounded-2xl p-1.5">
            {[
                { href: '/projects', label: 'Projects' },
                { href: '/work-journey', label: 'Work Journey' },
                { href: '/gallery', label: 'Art Gallery' },
            ].map(({ href, label }) => (
                    <a
                            href={href}
                            class={`px-4 py-1.5 rounded-xl text-base font-bold transition-colors ${
                                activePage === label
                                    ? 'bg-white text-black'
                                    : 'text-muted hover:text-white'
                            }`}
                    >
                        {label}
                    </a>
            ))}
        </div>

        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="group w-6 h-6 flex items-center justify-center" title="Toggle dark mode">
                <ThemeIcon class="text-muted group-hover:text-white transition-colors duration-200" />
            </button>

            <button class="group w-6 h-6 flex items-center justify-center" title="Toggle language">
                <LangIcon class="text-muted group-hover:text-white transition-colors duration-200" />
            </button>
        </div>

    </div>
</nav>

<main class="pt-16">
    <slot />
</main>

<!--
    КРОК 2: Toggle — теж is:inline, стоїть після кнопки в DOM.
    Простий addEventListener, нічого зайвого.
-->
<script is:inline>
    document.getElementById('theme-toggle').addEventListener('click', function () {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
</script>

<!-- GSAP анімації — звичайний бандлений скрипт, це нормально -->
<script>
    declare const gsap: any;
    declare const ScrollTrigger: any;

    function initAnimations() {
        if (typeof gsap === 'undefined') return;
        gsap.registerPlugin(ScrollTrigger);

        // Текст анімуємо як зазвичай
        gsap.from('[data-anim]', {
            y: 30,
            opacity: 0,
            duration: 1,
            ease: 'power3.out',
        });

        // КАРТИНКИ: кожна анімується окремо при появі
        document.querySelectorAll('[data-gallery-item-reveal]').forEach((item) => {
            gsap.from(item, {
                scrollTrigger: {
                    trigger: item,
                    start: 'top 92%', // спрацює, коли край картинки покажеться знизу
                    toggleActions: 'play none none none'
                },
                y: 40,
                opacity: 0,
                duration: 0.8,
                ease: 'power2.out',
            });
        });
    }

    initAnimations();
    document.addEventListener('astro:after-swap', initAnimations);
</script>
</body>
</html>