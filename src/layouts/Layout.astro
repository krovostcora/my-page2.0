---
import '../styles/global.css';
import Logo from "../components/icons/Logo.astro";
import ThemeIcon from "../components/icons/ThemeIcon.astro";
import LangIcon from "../components/icons/LangIcon.astro";
import { BASE_URL } from '../utils/base';
import { useTranslations } from '../utils/i18n';

interface Props {
    title?: string;
    activePage?: string;
}

const { lang = 'en' } = Astro.params;
const t = useTranslations(lang as any);
const { title = "My Portfolio", activePage = "" } = Astro.props;

const navLinks = [
    { href: `${BASE_URL}${lang}/projects`, label: t('nav.projects') },
    { href: `${BASE_URL}${lang}/work-journey`, label: t('nav.work') },
    { href: `${BASE_URL}${lang}/gallery`, label: t('nav.gallery') },
];

const locales = [
    { code: 'en', label: 'EN' },
    { code: 'uk', label: 'UA' },
    { code: 'es', label: 'ES' }
];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link
            rel="preload"
            href="/my-page2.0/fonts/KyivTypeSans-Regular-.woff2"
            as="font"
            type="font/woff2"
            crossorigin
    />

    <script is:inline>
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
</head>

<body class="font-sans transition-colors duration-300">

<nav id="main-header"
     style="background-color: #0D0D0D;"
     class="fixed top-0 left-0 right-0 z-50 h-16 flex items-center
            backdrop-blur-md border-b border-white/10
            transition-transform duration-300">

    <div class="flex items-center justify-between w-full px-6 md:px-12">

        <!-- Logo -->
        <a href={`${BASE_URL}${lang}/`}
           class="w-9 h-9 flex-shrink-0 hover:opacity-75 transition-opacity">
            <Logo class="w-full h-full text-white" />
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6">
            {navLinks.map(({ href, label }) => (
                    <a
                            href={href}
                            class={`relative py-1 text-sm font-bold transition-colors
                        ${activePage === label
                                ? 'text-white'
                                : 'text-zinc-400 hover:text-white'}`}
                    >
                        {label}
                        {activePage === label && (
                                <span class="absolute -bottom-1 left-0 right-0 h-0.5 rounded-full" style="background-color: #c9a84c;"></span>
                        )}
                    </a>
            ))}
        </div>

        <!-- Controls -->
        <div class="flex items-center gap-2">

            <button id="theme-toggle"
                    class="w-9 h-9 flex items-center justify-center rounded-lg
                           hover:bg-white/10 transition-colors"
                    title="Toggle dark mode">
                <ThemeIcon class="w-5 h-5 text-zinc-400 hover:text-white transition-colors" />
            </button>

            <div class="relative group">
                <button class="w-9 h-9 flex items-center justify-center rounded-lg
                               hover:bg-white/10 transition-colors"
                        title="Toggle language">
                    <LangIcon class="w-5 h-5 text-zinc-400 hover:text-white transition-colors" />
                </button>

                <div class="absolute right-0 mt-1 pt-1 w-20
                            opacity-0 pointer-events-none
                            group-hover:opacity-100 group-hover:pointer-events-auto
                            transition-all duration-150">
                    <div class="backdrop-blur-md border border-white/10 rounded-xl shadow-xl overflow-hidden"
                         style="background-color: #1A1A1A;">
                        {locales.map((loc) => (
                                <button
                                        data-lang={loc.code}
                                        class={`lang-switch-btn w-full text-left px-4 py-2.5 text-[11px] font-bold
                                        hover:bg-white/10 transition-colors
                                        ${lang === loc.code
                                            ? 'text-zinc-400 hover:text-white'
                                            : 'text-zinc-400 hover:text-white'}`}
                                        style={lang === loc.code ? 'color: #c9a84c;' : ''}
                                >
                                    {loc.label}
                                </button>
                        ))}
                    </div>
                </div>
            </div>

            <button id="mobile-menu-open"
                    class="md:hidden w-9 h-9 flex items-center justify-center
                           rounded-lg hover:bg-white/10 transition-colors text-white">
                <svg width="20" height="20" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4 8h16M4 16h16" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu"
     class="fixed inset-0 z-[100] flex flex-col items-center justify-center
            opacity-0 pointer-events-none transition-all duration-300"
     style="background-color: #0D0D0D;">
    <button id="mobile-menu-close"
            class="absolute top-8 right-8 p-4 text-zinc-400 hover:text-white transition-colors">
        <svg width="28" height="28" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
        </svg>
    </button>
    <nav class="flex flex-col items-center gap-8">
        <a href={`${BASE_URL}${lang}/`}
           class="mobile-link text-4xl font-bold uppercase tracking-tighter text-white hover:opacity-75 transition-opacity">
            {t('nav.home')}
        </a>
        {navLinks.map(link => (
                <a href={link.href}
                   class="mobile-link text-4xl font-bold uppercase tracking-tighter text-white hover:opacity-75 transition-opacity">
                    {link.label}
                </a>
        ))}
    </nav>
</div>

<main class="pt-16">
    <slot />
</main>

<script is:inline>
    const btn = document.getElementById('theme-toggle');
    if (btn) {
        btn.onclick = () => {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        };
    }
</script>

<script is:inline>
    function switchLanguage(newLang) {
        localStorage.setItem('lang', newLang);
        const path = window.location.pathname;
        const newPath = path.replace(/\/(en|uk|es)(\/|$)/, '/' + newLang + '$2');
        window.location.href = newPath;
    }

    document.querySelectorAll('.lang-switch-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            switchLanguage(this.dataset.lang);
        });
    });
</script>

<script>
    declare const gsap: any;

    function initLayout() {
        const header = document.getElementById('main-header');
        const openBtn = document.getElementById('mobile-menu-open');
        const closeBtn = document.getElementById('mobile-menu-close');
        const menu = document.getElementById('mobile-menu');
        const links = document.querySelectorAll('.mobile-link');

        let lastScroll = 0;
        const handleScroll = () => {
            const currentScroll = window.scrollY;
            if (header) {
                header.style.transform = (currentScroll > lastScroll && currentScroll > 60)
                    ? 'translateY(-100%)'
                    : 'translateY(0)';
            }
            lastScroll = currentScroll;
        };

        window.removeEventListener('scroll', handleScroll);
        window.addEventListener('scroll', handleScroll, { passive: true });

        if (openBtn && closeBtn && menu && typeof gsap !== 'undefined') {
            const tl = gsap.timeline({ paused: true });
            tl.to(menu, { opacity: 1, pointerEvents: 'auto', duration: 0.3 })
                .from(links, { y: 20, opacity: 0, stagger: 0.1, duration: 0.3 }, "-=0.2");

            openBtn.onclick = () => { tl.play(); document.body.style.overflow = 'hidden'; };

            const closeMenu = () => { tl.reverse(); document.body.style.overflow = ''; };
            closeBtn.onclick = closeMenu;
            links.forEach(link => { (link as HTMLElement).onclick = closeMenu; });
        }
    }

    initLayout();
    document.addEventListener('astro:after-swap', initLayout);
</script>
</body>
</html>